NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxx

# Mapbox publishable token. Restrict to allowed URLs in the Mapbox dashboard.
NEXT_PUBLIC_MAPBOX_API_KEY=pk.xxx
# Optional: defaults to outdoors-v12 when unset.
NEXT_PUBLIC_MAPBOX_STYLE_ID=outdoors-v12

# Google Analytics 4 measurement ID (format: G-XXXXXXXX).
# When unset, the GA tag is not emitted (dev/preview stays untracked).
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXX
